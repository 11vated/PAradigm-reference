# gspl-reference is a spec repo, not a code repo. Almost nothing should ever
# land here. This .gitignore exists to prevent accidental commits of editor,
# OS, and tooling debris.

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-workspace
*.sublime-project
.nvim.lua

# Rust (in case anyone scaffolds an implementation crate inside this repo by mistake)
target/
Cargo.lock
**/*.rs.bk

# Node (same reason)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
dist/
build/
.next/
.nuxt/
.cache/
.parcel-cache/
.turbo/

# Vitest config timestamp pollution (this was a real problem in the prototype)
vite.config.*.timestamp-*
vitest.config.*.timestamp-*

# Python (in case any tools/ scripts get scaffolded)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# Secrets — never, under any circumstances
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials.json

# Build artifacts
*.o
*.so
*.dylib
*.dll
*.a
*.exe

# Logs
*.log
logs/

# Coverage
coverage/
.coverage
.nyc_output/
htmlcov/

# Generated docs (if anyone runs a doc generator against the spec)
_site/
.docusaurus/
site/

# Local scratch
scratch/
tmp/
*.tmp
*.bak
